# Database (Supabase - PostgreSQL na nuvem)
# Pegue a connection string em: Supabase Dashboard → Settings → Database → Connection string (URI)
# Use a senha que você definiu ao criar o projeto
DATABASE_URL="postgresql://postgres:SUA_SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"

# Autenticação: Supabase Auth (login, registro, esqueci senha)
# Em Supabase Dashboard → Authentication → URL Configuration, adicione em Redirect URLs:
#   http://localhost:3000/redefinir-senha
#   https://seu-dominio.vercel.app/redefinir-senha

# App
NODE_ENV="development"
PORT=3000

# Admin master (e-mail que tem acesso total ao painel admin)
NEXT_PUBLIC_MASTER_ADMIN_EMAIL="seu-email@exemplo.com"

# Supabase API (Storage, Realtime, etc.)
# Pegue em: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-chave-anon-aqui"
SUPABASE_SERVICE_ROLE_KEY="sua-chave-service-role-aqui"

# API Keys (quando necessário)
# GOOGLE_MAPS_API_KEY=""
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLIC_KEY=""

# App do passageiro (Mai Drive) - links das lojas na página /baixar
# NEXT_PUBLIC_PASSENGER_APP_PLAY_STORE_URL="https://play.google.com/store/apps/details?id=..."
# NEXT_PUBLIC_PASSENGER_APP_APP_STORE_URL="https://apps.apple.com/app/..."

